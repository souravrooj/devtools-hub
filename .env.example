# =============================================================================
# DevTools Hub - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values.
#
#   cp .env.example .env
#
# IMPORTANT:
#   - NEVER commit .env.local to Git (it is in .gitignore)
#   - Variables prefixed with NEXT_PUBLIC_ are exposed to the browser
#   - Variables WITHOUT the prefix are server-side only (secure)
# =============================================================================


# -----------------------------------------------------------------------------
# APP CONFIG  (Required)
# -----------------------------------------------------------------------------

# The public-facing base URL of your application.
# Development:  http://localhost:3000
# Production:   https://your-vercel-domain.vercel.app  (or custom domain)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Display name shown in the browser tab, header, and SEO meta tags
NEXT_PUBLIC_APP_NAME=DevTools Hub

# Short description used in SEO meta tags
NEXT_PUBLIC_APP_DESCRIPTION=A centralized hub of developer tools - JSON formatter, password generator, markdown preview, Base64, and more.


# -----------------------------------------------------------------------------
# DATABASE - MongoDB Atlas  (Optional for v1, Required for v2+ features)
# -----------------------------------------------------------------------------

# Full MongoDB connection URI from MongoDB Atlas.
# Format:
#   mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
#
# How to get this:
#   1. Go to https://cloud.mongodb.com
#   2. Create a free cluster (M0 Sandbox)
#   3. Click "Connect" → "Connect your application"
#   4. Copy the connection string and replace <password> with your DB user password
#
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# The name of the MongoDB database to use.
# This is the dbname in the URI above. Keep it consistent.
MONGODB_DB_NAME=devtools_hub


# -----------------------------------------------------------------------------
# AUTHENTICATION - NextAuth.js  (Future feature — user accounts & favorites)
# -----------------------------------------------------------------------------

# A random secret string used to encrypt NextAuth session tokens.
# Generate one with: openssl rand -base64 32
# Or use: https://generate-secret.vercel.app/32
NEXTAUTH_SECRET=your_nextauth_secret_here

# The canonical URL of your application (same as NEXT_PUBLIC_APP_URL but server-side).
# Must match exactly — trailing slash matters.
# Development:  http://localhost:3000
# Production:   https://your-domain.com
NEXTAUTH_URL=http://localhost:3000


# -----------------------------------------------------------------------------
# OPTIONAL FUTURE INTEGRATIONS
# -----------------------------------------------------------------------------

# (Future) Analytics — e.g., Vercel Analytics, Plausible, or Umami
# NEXT_PUBLIC_ANALYTICS_ID=

# (Future) GitHub OAuth for NextAuth social login
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# (Future) Google OAuth for NextAuth social login
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=


# =============================================================================
# Notes:
#
#  - All NEXT_PUBLIC_* variables are visible in the browser bundle.
#    DO NOT put secrets or credentials in NEXT_PUBLIC_* variables.
#
#  - Server-only variables (MONGODB_URI, NEXTAUTH_SECRET, etc.) are
#    never sent to the browser and are safe for credentials.
#
#  - When deploying to Vercel, add all variables in:
#    Vercel Dashboard → Project → Settings → Environment Variables
# =============================================================================
